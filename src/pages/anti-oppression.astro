---
import BaseLayout from "../layouts/BaseLayout.astro";
import { marked } from "marked";
import fs from "node:fs";
import path from "node:path";

const cocRaw = fs.readFileSync(
  path.join(process.cwd(), "src/content/home/COCUpdate.md"),
  "utf-8"
);
const cocHtml = marked.parse(cocRaw);
---

<BaseLayout title="Anti-Oppression - Gamma Space">
  <div class="max-w-[800px]">
    <h1>Anti-Oppression</h1>
    <Fragment set:html={cocHtml} />
  </div>
</BaseLayout>
