---
import BaseLayout from "../layouts/BaseLayout.astro";
import { marked } from "marked";
import fs from "node:fs";
import path from "node:path";

const linksRaw = fs.readFileSync(
  path.join(process.cwd(), "src/content/links/links.md"),
  "utf-8"
);
const linksHtml = marked.parse(linksRaw);
---

<BaseLayout title="Links - Gamma Space">
  <div class="link-box link-sep px-4 py-2 mb-6 md:max-w-[700px] md:mx-auto">
    <Fragment set:html={linksHtml} />
  </div>
</BaseLayout>
