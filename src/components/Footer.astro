    </div>
    <div class="mt-8 md:mt-0 md:order-1">
      <p
        class="text-center md:text-left md:pr-8 text-base leading-6 text-black"
      >
        &copy; 2011-{curDate} Gamma Space Collaborative Studio, a registered non-profit
        N<sup class="sups">o.</sup> 839164-5
      </p>
      <p class="text-center md:text-left md:pr-8 text-base leading-6 text-black mt-4 md:mt-0">
        <a href="/anti-oppression" class="underline hover:text-gray-500">Anti-Oppression & Code of Conduct</a>
      </p>
    </div>
  </div>
</footer>
